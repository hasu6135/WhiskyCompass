# Rakuten Web Service (Ichiba Item Search API)
RAKUTEN_APP_ID=your_application_id
RAKUTEN_ACCESS_KEY=your_access_key
RAKUTEN_AFFILIATE_ID=your_affiliate_id

# Amazon Associate tracking ID (used in Amazon product-search links)
AMAZON_TAG=yourtag-22

# Optional: set when LocalLM requires an explicit model name
LM_STUDIO_MODEL=your-local-model-id
